  "cli": { "version": ">= 12.0.0", "appVersionSource": "local" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "ATTESTATION_NOTE": "pair with ATTESTATION_MODE=dev on the server" }
